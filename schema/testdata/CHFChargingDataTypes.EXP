AllocationRetentionPriority ::= SEQUENCE {
   priorityLevel             [1] IMPLICIT INTEGER, 
   preemptionCapability      [2] IMPLICIT ENUMERATED {
      nOT-PREEMPT    ( 0 ), 
      mAY-PREEMPT    ( 1 ) }, 
   preemptionVulnerability   [3] IMPLICIT ENUMERATED {
      nOT-PREEMPTABLE    ( 0 ), 
      pREEMPTABLE        ( 1 ) }}

AMFID      ::= OCTET STRING ( SIZE( 6 ) )

AuthorizedQoSInformation ::= SEQUENCE {
   fiveQi            [1] IMPLICIT INTEGER, 
   aRP               [2] IMPLICIT SEQUENCE {
      priorityLevel             [1] IMPLICIT INTEGER, 
      preemptionCapability      [2] IMPLICIT ENUMERATED {
         nOT-PREEMPT    ( 0 ), 
         mAY-PREEMPT    ( 1 ) }, 
      preemptionVulnerability   [3] IMPLICIT ENUMERATED {
         nOT-PREEMPTABLE    ( 0 ), 
         pREEMPTABLE        ( 1 ) }}, 
   priorityLevel     [3] IMPLICIT INTEGER OPTIONAL, 
   averWindow        [4] IMPLICIT INTEGER OPTIONAL, 
   maxDataBurstVol   [5] IMPLICIT INTEGER OPTIONAL}

Bitrate    ::= OCTET STRING

ChargingSessionIdentifier ::= OCTET STRING

DataNetworkNameIdentifier ::= IA5String  ( SIZE( 1 .. 63 ) )

DNNSelectionMode ::= ENUMERATED {
   uEorNetworkProvidedSubscriptionVerified    ( 0 ), 
   uEProvidedSubscriptionNotVerified          ( 1 ), 
   networkProvidedSubscriptionNotVerified     ( 2 ) }

FiveGQoSInformation ::= SEQUENCE {
   fiveQi                   [1] IMPLICIT INTEGER, 
   aRP                      [2] IMPLICIT SEQUENCE {
      priorityLevel             [1] IMPLICIT INTEGER, 
      preemptionCapability      [2] IMPLICIT ENUMERATED {
         nOT-PREEMPT    ( 0 ), 
         mAY-PREEMPT    ( 1 ) }, 
      preemptionVulnerability   [3] IMPLICIT ENUMERATED {
         nOT-PREEMPTABLE    ( 0 ), 
         pREEMPTABLE        ( 1 ) }}, 
   qoSNotificationControl   [3] IMPLICIT BOOLEAN OPTIONAL, 
   reflectiveQos            [4] IMPLICIT BOOLEAN OPTIONAL, 
   maxbitrateUL             [5] IMPLICIT OCTET STRING OPTIONAL, 
   maxbitrateDL             [6] IMPLICIT OCTET STRING OPTIONAL, 
   guaranteedbitrateUL      [7] IMPLICIT OCTET STRING OPTIONAL, 
   guaranteedbitrateDL      [8] IMPLICIT OCTET STRING OPTIONAL, 
   priorityLevel            [9] IMPLICIT INTEGER OPTIONAL, 
   averWindow               [10] IMPLICIT INTEGER OPTIONAL, 
   maxDataBurstVol          [11] IMPLICIT INTEGER OPTIONAL, 
   maxPacketLossRateDL      [12] IMPLICIT INTEGER OPTIONAL, 
   maxPacketLossRateUL      [13] IMPLICIT INTEGER OPTIONAL}

MultipleUnitUsage ::= SEQUENCE {
   ratingGroup          [0] IMPLICIT INTEGER, 
   usedUnitContainers   [1] IMPLICIT SEQUENCE  OF
      SEQUENCE {
         serviceIdentifier          [0] IMPLICIT INTEGER ( 0 .. 4294967295 ) OPTIONAL, 
         time                       [1] IMPLICIT INTEGER OPTIONAL, 
         triggers                   [2] IMPLICIT SEQUENCE  OF
            CHOICE {
               sMFTrigger     [0] IMPLICIT INTEGER {
                  startOfPDUSession                           ( 1 ), 
                  atartOfServiceDataFlowNoSession             ( 2 ), 
                  qoSChange                                   ( 100 ), 
                  userLocationChange                          ( 101 ), 
                  servingNodeChange                           ( 102 ), 
                  presenceReportingAreaChange                 ( 103 ), 
                  threeGPPPSDataOffStatusChange               ( 104 ), 
                  tariffTimeChange                            ( 105 ), 
                  uETimeZoneChange                            ( 106 ), 
                  pLMNChange                                  ( 107 ), 
                  rATTypeChange                               ( 108 ), 
                  sessionAMBRChange                           ( 109 ), 
                  additionOfUPF                               ( 110 ), 
                  removalOfUPF                                ( 111 ), 
                  pDUSessionExpiryDataTimeLimit               ( 200 ), 
                  pDUSessionExpiryDataVolumeLimit             ( 201 ), 
                  pDUSessionExpiryDataEventLimit              ( 202 ), 
                  pDUSessionExpiryChargingConditionChanges    ( 203 ), 
                  ratingGroupDataTimeLimit                    ( 300 ), 
                  ratingGroupDataVolumeLimit                  ( 301 ), 
                  ratingGroupDataEventLimit                   ( 302 ), 
                  timeThresholdReached                        ( 400 ), 
                  volumeThresholdReached                      ( 401 ), 
                  unitThresholdReached                        ( 402 ), 
                  timeQuotaExhausted                          ( 403 ), 
                  volumeQuotaExhausted                        ( 404 ), 
                  unitQuotaExhausted                          ( 405 ), 
                  expiryOfQuotaValidityTime                   ( 406 ), 
                  reAuthorizationRequest                      ( 407 ), 
                  startOfServiceDataFlowNoValidQuota          ( 408 ), 
                  otherQuotaType                              ( 409 ), 
                  terminationOfServiceDataFlow                ( 500 ), 
                  managementIntervention                      ( 501 ), 
                  unitCountInactivityTimer                    ( 502 ), 
                  endOfPDUSession                             ( 503 ), 
                  cHFResponseWithSessionTermination           ( 504 ), 
                  cHFAbortRequest                             ( 505 ), 
                  abnormalRelease                             ( 506 ), 
                  qoSFlowExpiryDataTimeLimit                  ( 600 ), 
                  qoSFlowExpiryDataVolumeLimit                ( 601 )}}, 
         triggerTimeStamp           [3] IMPLICIT OCTET STRING ( SIZE( 9 ) ) OPTIONAL, 
         dataTotalVolume            [4] IMPLICIT INTEGER OPTIONAL, 
         dataVolumeUplink           [5] IMPLICIT INTEGER OPTIONAL, 
         dataVolumeDownlink         [6] IMPLICIT INTEGER OPTIONAL, 
         serviceSpecificUnits       [7] IMPLICIT INTEGER OPTIONAL, 
         eventTimeStamp             [8] IMPLICIT OCTET STRING ( SIZE( 9 ) ) OPTIONAL, 
         localSequenceNumber        [9] IMPLICIT INTEGER ( 0 .. 4294967295 ) OPTIONAL, 
         ratingIndicator            [10] IMPLICIT BOOLEAN OPTIONAL, 
         pDUContainerInformation    [11] IMPLICIT SEQUENCE {
            chargingRuleBaseName                 [0] IMPLICIT IA5String  OPTIONAL, 
            aFCorrelationInformation             [1] IMPLICIT OCTET STRING OPTIONAL, 
            timeOfFirstUsage                     [2] IMPLICIT OCTET STRING ( SIZE( 9 ) ) OPTIONAL, 
            timeOfLastUsage                      [3] IMPLICIT OCTET STRING ( SIZE( 9 ) ) OPTIONAL, 
            qoSInformation                       [4] IMPLICIT SEQUENCE {
               fiveQi                   [1] IMPLICIT INTEGER, 
               aRP                      [2] IMPLICIT SEQUENCE {
                  priorityLevel             [1] IMPLICIT INTEGER, 
                  preemptionCapability      [2] IMPLICIT ENUMERATED {
                     nOT-PREEMPT    ( 0 ), 
                     mAY-PREEMPT    ( 1 ) }, 
                  preemptionVulnerability   [3] IMPLICIT ENUMERATED {
                     nOT-PREEMPTABLE    ( 0 ), 
                     pREEMPTABLE        ( 1 ) }}, 
               qoSNotificationControl   [3] IMPLICIT BOOLEAN OPTIONAL, 
               reflectiveQos            [4] IMPLICIT BOOLEAN OPTIONAL, 
               maxbitrateUL             [5] IMPLICIT OCTET STRING OPTIONAL, 
               maxbitrateDL             [6] IMPLICIT OCTET STRING OPTIONAL, 
               guaranteedbitrateUL      [7] IMPLICIT OCTET STRING OPTIONAL, 
               guaranteedbitrateDL      [8] IMPLICIT OCTET STRING OPTIONAL, 
               priorityLevel            [9] IMPLICIT INTEGER OPTIONAL, 
               averWindow               [10] IMPLICIT INTEGER OPTIONAL, 
               maxDataBurstVol          [11] IMPLICIT INTEGER OPTIONAL, 
               maxPacketLossRateDL      [12] IMPLICIT INTEGER OPTIONAL, 
               maxPacketLossRateUL      [13] IMPLICIT INTEGER OPTIONAL} OPTIONAL, 
            userLocationInformation              [5] IMPLICIT OCTET STRING OPTIONAL, 
            presenceReportingAreaInfo            [6] IMPLICIT SEQUENCE {
               presenceReportingAreaIdentifier     [0] IMPLICIT OCTET STRING, 
               presenceReportingAreaStatus         [1] IMPLICIT ENUMERATED {
                  insideArea     ( 0 ), 
                  outsideArea    ( 1 ), 
                  inactive       ( 2 ), 
                  unknown        ( 3 ) } OPTIONAL, 
               presenceReportingAreaElementsList   [2] IMPLICIT OCTET STRING OPTIONAL, 
               presenceReportingAreaNode           [3] IMPLICIT BIT STRING {
                  oCS  (0 ), 
                  pCRF  (1 )} OPTIONAL} OPTIONAL, 
            rATType                              [7] IMPLICIT INTEGER ( 0 .. 255 ) OPTIONAL, 
            sponsorIdentity                      [8] IMPLICIT OCTET STRING OPTIONAL, 
            applicationServiceProviderIdentity   [9] IMPLICIT OCTET STRING OPTIONAL, 
            servingNetworkFunctionID             [10] IMPLICIT SEQUENCE  OF
               SEQUENCE {
                  servingNetworkFunctionInformation   [0] IMPLICIT SEQUENCE {
                     networkFunctionality            [0] IMPLICIT ENUMERATED {
                        cHF         ( 0 ), 
                        sMF         ( 1 ), 
                        aMF         ( 2 ), 
                        sMSF        ( 3 ) }, 
                     networkFunctionName             [1] IMPLICIT IA5String  ( SIZE( 1 .. 36 ) ) OPTIONAL, 
                     networkFunctionIPv4Address      [2] CHOICE {
                        iPBinaryAddress              CHOICE {
                           iPBinV4Address     [0] IMPLICIT OCTET STRING ( SIZE( 4 ) ), 
                           iPBinV6Address     CHOICE {
                              iPBinV6Address               [1] IMPLICIT OCTET STRING ( SIZE( 16 ) ), 
                              iPBinV6AddressWithPrefix     [4] IMPLICIT SEQUENCE {
                                 iPBinV6Address           OCTET STRING ( SIZE( 16 ) ), 
                                 pDPAddressPrefixLength   INTEGER ( 1 .. 64 ) DEFAULT 64}}}, 
                        iPTextRepresentedAddress     CHOICE {
                           iPTextV4Address     [2] IMPLICIT IA5String  ( SIZE( 7 .. 15 ) ), 
                           iPTextV6Address     [3] IMPLICIT IA5String  ( SIZE( 15 .. 45 ) )}} OPTIONAL, 
                     networkFunctionPLMNIdentifier   [3] IMPLICIT OCTET STRING ( SIZE( 3 ) ) OPTIONAL, 
                     networkFunctionIPv6Address      [4] CHOICE {
                        iPBinaryAddress              CHOICE {
                           iPBinV4Address     [0] IMPLICIT OCTET STRING ( SIZE( 4 ) ), 
                           iPBinV6Address     CHOICE {
                              iPBinV6Address               [1] IMPLICIT OCTET STRING ( SIZE( 16 ) ), 
                              iPBinV6AddressWithPrefix     [4] IMPLICIT SEQUENCE {
                                 iPBinV6Address           OCTET STRING ( SIZE( 16 ) ), 
                                 pDPAddressPrefixLength   INTEGER ( 1 .. 64 ) DEFAULT 64}}}, 
                        iPTextRepresentedAddress     CHOICE {
                           iPTextV4Address     [2] IMPLICIT IA5String  ( SIZE( 7 .. 15 ) ), 
                           iPTextV6Address     [3] IMPLICIT IA5String  ( SIZE( 15 .. 45 ) )}}, 
                     networkFunctionFQDN             [5] CHOICE {
                        iPAddress      [0] CHOICE {
                           iPBinaryAddress              CHOICE {
                              iPBinV4Address     [0] IMPLICIT OCTET STRING ( SIZE( 4 ) ), 
                              iPBinV6Address     CHOICE {
                                 iPBinV6Address               [1] IMPLICIT OCTET STRING ( SIZE( 16 ) ), 
                                 iPBinV6AddressWithPrefix     [4] IMPLICIT SEQUENCE {
                                    iPBinV6Address           OCTET STRING ( SIZE( 16 ) ), 
                                    pDPAddressPrefixLength   INTEGER ( 1 .. 64 ) DEFAULT 64}}}, 
                           iPTextRepresentedAddress     CHOICE {
                              iPTextV4Address     [2] IMPLICIT IA5String  ( SIZE( 7 .. 15 ) ), 
                              iPTextV6Address     [3] IMPLICIT IA5String  ( SIZE( 15 .. 45 ) )}}, 
                        domainName     [1] IMPLICIT GraphicString}}, 
                  aMFIdentifier                       [1] IMPLICIT OCTET STRING ( SIZE( 6 ) ) OPTIONAL} OPTIONAL, 
            uETimeZone                           [11] IMPLICIT OCTET STRING ( SIZE( 2 ) ) OPTIONAL, 
            threeGPPPSDataOffStatus              [12] IMPLICIT ENUMERATED {
               active      ( 0 ), 
               inactive    ( 1 ) } OPTIONAL} OPTIONAL, 
         quotaManagementIndicator   [12] IMPLICIT BOOLEAN OPTIONAL} OPTIONAL, 
   uPFID                [2] IMPLICIT IA5String  ( SIZE( 1 .. 36 ) ) OPTIONAL}

NetworkFunctionality ::= ENUMERATED {
   cHF         ( 0 ), 
   sMF         ( 1 ), 
   aMF         ( 2 ), 
   sMSF        ( 3 ) }

NetworkFunctionInformation ::= SEQUENCE {
   networkFunctionality            [0] IMPLICIT ENUMERATED {
      cHF         ( 0 ), 
      sMF         ( 1 ), 
      aMF         ( 2 ), 
      sMSF        ( 3 ) }, 
   networkFunctionName             [1] IMPLICIT IA5String  ( SIZE( 1 .. 36 ) ) OPTIONAL, 
   networkFunctionIPv4Address      [2] CHOICE {
      iPBinaryAddress              CHOICE {
         iPBinV4Address     [0] IMPLICIT OCTET STRING ( SIZE( 4 ) ), 
         iPBinV6Address     CHOICE {
            iPBinV6Address               [1] IMPLICIT OCTET STRING ( SIZE( 16 ) ), 
            iPBinV6AddressWithPrefix     [4] IMPLICIT SEQUENCE {
               iPBinV6Address           OCTET STRING ( SIZE( 16 ) ), 
               pDPAddressPrefixLength   INTEGER ( 1 .. 64 ) DEFAULT 64}}}, 
      iPTextRepresentedAddress     CHOICE {
         iPTextV4Address     [2] IMPLICIT IA5String  ( SIZE( 7 .. 15 ) ), 
         iPTextV6Address     [3] IMPLICIT IA5String  ( SIZE( 15 .. 45 ) )}} OPTIONAL, 
   networkFunctionPLMNIdentifier   [3] IMPLICIT OCTET STRING ( SIZE( 3 ) ) OPTIONAL, 
   networkFunctionIPv6Address      [4] CHOICE {
      iPBinaryAddress              CHOICE {
         iPBinV4Address     [0] IMPLICIT OCTET STRING ( SIZE( 4 ) ), 
         iPBinV6Address     CHOICE {
            iPBinV6Address               [1] IMPLICIT OCTET STRING ( SIZE( 16 ) ), 
            iPBinV6AddressWithPrefix     [4] IMPLICIT SEQUENCE {
               iPBinV6Address           OCTET STRING ( SIZE( 16 ) ), 
               pDPAddressPrefixLength   INTEGER ( 1 .. 64 ) DEFAULT 64}}}, 
      iPTextRepresentedAddress     CHOICE {
         iPTextV4Address     [2] IMPLICIT IA5String  ( SIZE( 7 .. 15 ) ), 
         iPTextV6Address     [3] IMPLICIT IA5String  ( SIZE( 15 .. 45 ) )}}, 
   networkFunctionFQDN             [5] CHOICE {
      iPAddress      [0] CHOICE {
         iPBinaryAddress              CHOICE {
            iPBinV4Address     [0] IMPLICIT OCTET STRING ( SIZE( 4 ) ), 
            iPBinV6Address     CHOICE {
               iPBinV6Address               [1] IMPLICIT OCTET STRING ( SIZE( 16 ) ), 
               iPBinV6AddressWithPrefix     [4] IMPLICIT SEQUENCE {
                  iPBinV6Address           OCTET STRING ( SIZE( 16 ) ), 
                  pDPAddressPrefixLength   INTEGER ( 1 .. 64 ) DEFAULT 64}}}, 
         iPTextRepresentedAddress     CHOICE {
            iPTextV4Address     [2] IMPLICIT IA5String  ( SIZE( 7 .. 15 ) ), 
            iPTextV6Address     [3] IMPLICIT IA5String  ( SIZE( 15 .. 45 ) )}}, 
      domainName     [1] IMPLICIT GraphicString}}

